{
  "name": "@ribbonflow/react",
  "version": "0.1.0",
  "type": "module",
  "description": "Thin React <FlowEmbed> adapter over ribbonflow's mountFlowAuto — renders an animated flow (or flow-set) diagram and updates on prop change.",
  "license": "MIT",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "vite build && node -e \"require('fs').copyFileSync('src/index.d.ts','dist/index.d.ts')\""
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "ribbonflow": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
