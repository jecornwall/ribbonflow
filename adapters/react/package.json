{
  "name": "@flow-designer/react",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Thin React <FlowEmbed> adapter over @flow-designer/library's mountFlowAuto. Becomes @ribbonflow/react at the repo split.",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "scripts": {
    "build": "vite build && node -e \"require('fs').copyFileSync('src/index.d.ts','dist/index.d.ts')\""
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@flow-designer/library": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
