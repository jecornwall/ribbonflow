{
  "name": "@flow-designer/library",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Shared flow library — simulation engine, curve maths, renderer, and the flow format. Two faces: <FlowEmbed> (slide-facing) and /internals (designer-facing).",
  "exports": {
    ".": "./src/index.js",
    "./internals": "./src/internals.js",
    "./render": "./src/render/index.js",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.json",
    "test": "node --test src/core/*.test.js src/format/*.test.js src/render/*.test.js test/*.test.js"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "linkedom": "^0.18.12",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vue": "^3.4.0"
  }
}
